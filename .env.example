# PassportAI — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it is listed in .gitignore

# ---- Ollama (required) ----
# URL of the local Ollama server
OLLAMA_HOST=http://localhost:11434

# Model name as registered in Ollama (must be pulled first)
# To pull: ollama pull gemma4:12b-q4_k_m
OLLAMA_MODEL=gemma4:12b-q4_k_m

# Ollama request timeout in seconds (large model may be slow)
OLLAMA_TIMEOUT=120

# ---- Storage Mode ----
# "local" — save files to LOCAL_OUTPUT_DIR (default, no cloud needed)
# "s3"    — save files to AWS S3 (requires AWS credentials below)
STORAGE_MODE=local

# ---- Local Storage ----
# Directory where DPP packages are saved (relative to project root)
LOCAL_OUTPUT_DIR=./output

# ---- AWS S3 Storage (only needed if STORAGE_MODE=s3) ----
AWS_REGION=eu-west-1
AWS_S3_BUCKET=passportai-passports
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: custom endpoint URL (e.g. for MinIO or localstack)
AWS_ENDPOINT_URL=

# ---- Server URLs ----
# Base URL where passport files are served (used to build passport_url and QR codes)
# For local development: http://localhost:8000
# For production: https://your-domain.com
HOSTING_URL=http://localhost:8000

# FastAPI server port
FASTAPI_PORT=8000

# Gradio UI port
GRADIO_PORT=7860

# ---- External APIs ----
# EU VIES VAT Verification Service (SOAP)
# Default endpoint — change only if EU updates the URL
VIES_API_URL=https://ec.europa.eu/taxation_customs/vies/services/checkVatService

# ---- Logging ----
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log to file (leave empty to log to stdout only)
LOG_FILE=

# ---- Feature Flags ----
# Enable VIES VAT verification (requires internet access)
ENABLE_VIES_CHECK=true

# Enable AWS S3 upload even if STORAGE_MODE=local (useful for backup)
ENABLE_S3_BACKUP=false

# Skip LCA calculation if not needed (speeds up generation)
ENABLE_LCA_ESTIMATION=true

# ---- Demo / Development ----
# Set to "true" to use mock Ollama responses (for UI testing without GPU)
USE_MOCK_OLLAMA=false

# Mock response delay in seconds (simulates real model speed)
MOCK_DELAY_SECONDS=2
