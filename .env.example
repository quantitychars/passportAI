# PassportAI — Environment Variables
# Copy this file to .env and fill in your values:
#   copy .env.example .env
#
# NEVER commit .env to git — it is listed in .gitignore

# ---- Ollama (required) ----
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_TIMEOUT=600

# ---- Storage Mode ----
# local — save files to LOCAL_OUTPUT_DIR
# s3    — upload generated artifacts to AWS S3
STORAGE_MODE=local

# ---- Local Storage ----
LOCAL_OUTPUT_DIR=./output
HOSTING_URL=http://localhost:8000

# ---- AWS S3 Storage (only needed if STORAGE_MODE=s3) ----
AWS_REGION=eu-west-1
AWS_S3_BUCKET=
AWS_S3_PREFIX=passports

# Public URL base used to render links after upload.
# Use a CloudFront domain or public custom domain when possible.
# Example: https://dpp.example.com
PUBLIC_BASE_URL=

# Optional custom endpoint for MinIO/localstack.
AWS_ENDPOINT_URL=

# Optional. Prefer bucket policy instead of ACL.
# Leave empty unless your bucket explicitly requires object ACLs.
AWS_S3_ACL=

# Credentials:
# Prefer AWS CLI profile / IAM role / temporary credentials.
# For local hackathon demo only, you may use env vars:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ---- Server Ports ----
FASTAPI_PORT=8000
GRADIO_PORT=7860

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FILE=

# ---- Demo / Development ----
USE_MOCK_OLLAMA=false
MOCK_DELAY_SECONDS=2
