{# templates/gap_report.html.jinja2 — human-readable DataAuditAgent report #}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>PassportAI Gap Report — {{ product_context.product_name }}</title>
  <style>
    :root {
      --ink: #111827;
      --muted: #6b7280;
      --line: #e5e7eb;
      --panel: #f9fafb;
      --red: #991b1b;
      --red-bg: #fef2f2;
      --amber: #92400e;
      --amber-bg: #fffbeb;
      --green: #065f46;
      --green-bg: #ecfdf5;
      --blue: #1e3a8a;
      --blue-bg: #eff6ff;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      padding: 32px;
      color: var(--ink);
      background: #ffffff;
      font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
      line-height: 1.48;
    }
    .page { max-width: 1080px; margin: 0 auto; }
    .hero {
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 28px;
      background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
      margin-bottom: 22px;
    }
    h1 { margin: 0 0 8px; font-size: 32px; letter-spacing: -0.04em; }
    h2 { margin: 28px 0 12px; font-size: 22px; letter-spacing: -0.02em; }
    h3 { margin: 0 0 8px; font-size: 16px; }
    p { margin: 0 0 10px; }
    .muted { color: var(--muted); }
    .meta { color: var(--muted); font-size: 13px; }
    .grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 14px; }
    .card {
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 16px;
      background: #ffffff;
    }
    .span-3 { grid-column: span 3; }
    .span-4 { grid-column: span 4; }
    .span-6 { grid-column: span 6; }
    .span-8 { grid-column: span 8; }
    .span-12 { grid-column: span 12; }
    .score { font-size: 46px; font-weight: 800; letter-spacing: -0.05em; }
    .status {
      display: inline-block;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .status-red { color: var(--red); background: var(--red-bg); }
    .status-amber { color: var(--amber); background: var(--amber-bg); }
    .status-green { color: var(--green); background: var(--green-bg); }
    .banner {
      border-radius: 14px;
      padding: 14px 16px;
      margin: 14px 0;
      border: 1px solid;
    }
    .banner-red { color: var(--red); background: var(--red-bg); border-color: #fecaca; }
    .banner-amber { color: var(--amber); background: var(--amber-bg); border-color: #fde68a; }
    .banner-green { color: var(--green); background: var(--green-bg); border-color: #a7f3d0; }
    table { width: 100%; border-collapse: collapse; margin: 8px 0 18px; font-size: 14px; }
    th, td { border-top: 1px solid var(--line); padding: 10px; text-align: left; vertical-align: top; }
    th { background: var(--panel); font-size: 12px; color: #374151; text-transform: uppercase; letter-spacing: 0.05em; }
    code { font-family: "SFMono-Regular", Consolas, monospace; font-size: 13px; }
    .pill { display: inline-block; padding: 3px 8px; border-radius: 999px; background: var(--panel); font-size: 12px; font-weight: 650; color: #374151; }
    .pill-red { color: var(--red); background: var(--red-bg); }
    .pill-amber { color: var(--amber); background: var(--amber-bg); }
    .pill-blue { color: var(--blue); background: var(--blue-bg); }
    .small { font-size: 13px; }
    .empty { color: var(--muted); padding: 12px 0; }
    .footer { margin-top: 34px; border-top: 1px solid var(--line); padding-top: 14px; color: var(--muted); font-size: 12px; }
    ul { margin-top: 6px; }
    .toolbar {
    display: flex;
    gap: 10px;
    margin-top: 18px;
    flex-wrap: wrap;
  }
  .btn {
    border: 1px solid #111827;
    background: #111827;
    color: white;
    border-radius: 999px;
    padding: 10px 14px;
    font-weight: 700;
    cursor: pointer;
  }
  .btn-secondary {
    background: white;
    color: #111827;
  }
  .process-note {
    background: var(--blue-bg);
    color: var(--blue);
    border: 1px solid #bfdbfe;
    border-radius: 14px;
    padding: 14px 16px;
    margin: 14px 0;
  }
  .gap-card {
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 16px;
    margin: 10px 0;
    background: #ffffff;
  }
  .gap-card h3 {
    margin: 0 0 6px;
    font-size: 18px;
  }
  .gap-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin: 8px 0;
  }
  .technical-path {
    color: var(--muted);
    font-family: "SFMono-Regular", Consolas, monospace;
    font-size: 12px;
    word-break: break-word;
  }
  details {
    margin-top: 10px;
  }
  summary {
    cursor: pointer;
    font-weight: 700;
  }
    @media print {
      body { padding: 18px; }
      .card, .hero, .banner { break-inside: avoid; }
      .toolbar { display: none; }
    }
  </style>
</head>
<body>
<div class="page">
  <section class="hero">
    <h1>PassportAI Gap Report</h1>
    <p class="muted">
      Human-readable remediation plan generated by <strong>{{ audit_metadata.source_label }}</strong>.
      This is not a legal certification and requires human review before official publication.
    </p>
    <p class="small muted">{{ audit_metadata.source_explanation }}</p>

    <div class="toolbar">
      <button class="btn" type="button" onclick="window.print()">Download / Save as PDF</button>
      <button class="btn btn-secondary" type="button" onclick="window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' })">View technical appendix</button>
    </div>
    <p class="meta">Schema {{ schema_version }} · Generated {{ generated_at }} · Passport ID {{ product_context.passport_id }}</p>
  </section>

  <section class="grid">
    <div class="card span-8">
      <h3>Product context</h3>
      <table>
        <tbody>
          <tr><th>Product</th><td>{{ product_context.product_name }}</td></tr>
          <tr><th>Brand / model</th><td>{{ product_context.brand_name }} / {{ product_context.model_name }}</td></tr>
          <tr><th>Product group</th><td>{{ product_context.product_group }}</td></tr>
          <tr><th>ESPR category</th><td>{{ product_context.espr_category }}</td></tr>
          <tr><th>Sector profile</th><td>{{ product_context.sector_profile }}</td></tr>
        </tbody>
      </table>
    </div>
    <div class="card span-4">
      <h3>Readiness</h3>
      <div class="score">{{ readiness.score }}</div>
      <p class="muted">/ 100 readiness score</p>
      {% if readiness.is_publishable %}
        <span class="status status-green">Publishable</span>
      {% elif publication_blockers.has_blockers %}
        <span class="status status-red">Publication blocked</span>
      {% else %}
        <span class="status status-amber">Draft only</span>
      {% endif %}
      <p style="margin-top:12px"><strong>Verdict:</strong> {{ readiness.verdict_label }}</p>
      <p><strong>Human review:</strong> {{ "required" if readiness.needs_human_review else "not flagged" }}</p>
    </div>
  </section>

  {% if publication_blockers.has_blockers %}
    <div class="banner banner-red">
      <strong>Publication is blocked until the issues below are resolved.</strong>
      <div class="small">The report fails closed: weak, missing, or contradictory evidence is not converted into publishable product truth.</div>
    </div>
  {% else %}
    <div class="banner banner-green">
      <strong>No publication blockers were reported by the audit.</strong>
      <div class="small">Recommended gaps may still be worth closing before submission.</div>
    </div>
  {% endif %}

  <section class="grid">
    <div class="card span-12">
      <h3>Audit summary</h3>
      <p>{{ readiness.summary }}</p>
    </div>
  </section>
  <section class="grid">
  <div class="card span-12">
    <h2 style="margin-top:0">Top fixes before publication</h2>
    {% if top_actions %}
      <table>
        <thead><tr><th>Priority</th><th>Owner</th><th>Action</th></tr></thead>
        <tbody>
          {% for action in top_actions %}
          <tr>
            <td><span class="pill {{ 'pill-red' if action.priority == 'now' else ('pill-amber' if action.priority == 'soon' else '') }}">{{ action.priority_label }}</span></td>
            <td>{{ action.owner_label }}</td>
            <td>
              {% if action.field_label %}<strong>{{ action.field_label }}</strong><br>{% endif %}
              {{ action.action }}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p class="empty">No immediate actions were provided by the audit.</p>
    {% endif %}
  </div>
</section>

  <section class="grid">
    <div class="card span-3"><h3>Blocking</h3><p class="score" style="font-size:30px">{{ gap_counts.blocking }}</p></div>
    <div class="card span-3"><h3>Missing</h3><p class="score" style="font-size:30px">{{ gap_counts.missing }}</p></div>
    <div class="card span-3"><h3>Weak evidence</h3><p class="score" style="font-size:30px">{{ gap_counts.weak_evidence }}</p></div>
    <div class="card span-3"><h3>Unverified</h3><p class="score" style="font-size:30px">{{ gap_counts.unverified }}</p></div>
  </section>

  {% if publication_blockers.blocking_items or publication_blockers.contradictions %}
<h2>Publication blockers</h2>

{% for item in publication_blockers.blocking_items %}
  <div class="banner banner-red">
    <strong>{{ item.label }}</strong><br>
    <span class="small">{{ item.reason }}</span><br>
    <span class="small muted">Suggested owner: {{ item.owner_label }}</span>
    {% if item.field %}
      <details>
        <summary>Technical field path</summary>
        <p class="technical-path">{{ item.field }}</p>
      </details>
    {% endif %}
  </div>
{% endfor %}

{% for item in publication_blockers.contradictions %}
  <div class="banner banner-red"><strong>Contradiction:</strong> {{ item }}</div>
{% endfor %}
{% endif %}

{% if vision_conflict.detected %}
  <div class="banner banner-amber">
    <strong>&#9888; Visual conflict detected</strong><br>
    {% if vision_conflict.gemma_hint %}
      Gemma identified <strong>{{ vision_conflict.gemma_hint }}</strong> but the product was classified as <strong>{{ vision_conflict.classified_as }}</strong>.
    {% else %}
      Gemma&#39;s image analysis produced a category hint that did not match the selected product category (<strong>{{ vision_conflict.classified_as }}</strong>).
    {% endif %}
    Please verify the product image matches the selected category before publication.
  </div>
{% endif %}

  {% macro gap_table(title, gaps, badge_class) -%}
    <h2>{{ title }}</h2>
    {% if gaps %}
      {% for gap in gaps %}
        <article class="gap-card">
          <h3>{{ gap.field_label }}</h3>
          <p class="muted">{{ gap.field_description }}</p>

          <div class="gap-meta">
            <span class="pill {{ badge_class }}">{{ gap.severity_label }}</span>
            {% if gap.display_blocking %}
              <span class="pill pill-red">Publication blocker</span>
            {% elif gap.blocking_downgraded %}
              <span class="pill pill-amber">Not a direct publication blocker</span>
            {% endif %}
            <strong>{{ gap.current_evidence_status_label }}</strong>
            {% if gap.evidence_source_label %}<span class="pill pill-blue">Evidence source: {{ gap.evidence_source_label }}</span>{% endif %}
            {% if gap.requires_supplier_confirmation %}<span class="pill pill-blue">Supplier confirmation needed</span>{% endif %}
          </div>

          <section class="grid">
            <div class="span-6">
              <h3>Current issue</h3>
              <p>{{ gap.reason }}</p>
            </div>
            <div class="span-6">
              <h3>Why it matters</h3>
              <p>{{ gap.why_it_matters }}</p>
            </div>
            <div class="span-6">
              <h3>Where to get the data</h3>
              <p>{{ gap.where_to_get_data }}</p>
            </div>
            <div class="span-6">
              <h3>Closure condition</h3>
              <p>{{ gap.closure_condition }}</p>
            </div>
          </section>

          {% if gap.acceptable_evidence %}
            <p class="small"><strong>Acceptable evidence:</strong> {{ gap.acceptable_evidence | join(', ') }}</p>
          {% endif %}

          <p class="small"><strong>Suggested owner:</strong> {{ gap.owner_label }}</p>

          {% if gap.source_processes %}
            <p class="small">
              <strong>Checked by:</strong>
              {% for process in gap.source_processes %}
                {{ process.label }}{% if not loop.last %}, {% endif %}
              {% endfor %}
            </p>
          {% endif %}

          <details>
            <summary>Technical field path</summary>
            <p class="technical-path">{{ gap.field }}</p>
            {% if gap.source_agents %}
              <p class="technical-path">Source processes: {{ gap.source_agents | join(', ') }}</p>
            {% endif %}
          </details>
        </article>
      {% endfor %}
    {% else %}
      <p class="empty">No issues in this group.</p>
    {% endif %}
  {%- endmacro %}

  {{ gap_table("1. Blocking gaps", gap_groups.blocking, "pill-red") }}
  {{ gap_table("2. Missing required data", gap_groups.missing, "pill-red") }}
  {{ gap_table("3. Weak evidence", gap_groups.weak_evidence, "pill-amber") }}
  {{ gap_table("4. Present but unverified", gap_groups.unverified, "pill-amber") }}
  {{ gap_table("5. Recommended improvements", gap_groups.recommended, "") }}

  <h2>Action plan</h2>
  {% if action_plan %}
  <table>
    <thead><tr><th>Priority</th><th>Owner</th><th>Action</th></tr></thead>
    <tbody>
      {% for action in action_plan %}
      <tr>
        <td><span class="pill {{ 'pill-red' if action.priority == 'now' else ('pill-amber' if action.priority == 'soon' else '') }}">{{ action.priority_label }}</span></td>
        <td>{{ action.owner_label }}</td>
        <td>
          {% if action.field_label %}<strong>{{ action.field_label }}</strong><br>{% endif %}
          {{ action.action }}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
    <p class="empty">No action plan was provided by the audit.</p>
  {% endif %}

  <section class="grid">
    <div class="card span-6">
      <h2 style="margin-top:0">Supplier request pack</h2>
      {% if supplier_requests %}
        {% for request in supplier_requests %}
          <p>
            <strong>{{ request.request_label }}</strong><br>
            <span class="small">{{ request.why_needed }}</span><br>
            <span class="muted small">Document type: {{ request.document_type }}</span>
            {% if request.technical_field_path %}
              <br><span class="technical-path">{{ request.technical_field_path }}</span>
            {% endif %}
          </p>
        {% endfor %}
      {% else %}
        <p class="empty">No supplier-specific requests.</p>
      {% endif %}
    </div>
    <div class="card span-6">
      <h2 style="margin-top:0">Where to get missing data</h2>
      {% if data_sources %}
        {% for source in data_sources %}
          <p>
            <strong>{{ source.missing_topic_label }}</strong><br>
            {{ source.source }}<br>
            <span class="muted small">{{ source.how_to_obtain }}</span><br>
            <span class="technical-path">{{ source.missing_topic }}</span>
          </p>
        {% endfor %}
      {% else %}
        <p class="empty">No data-source guidance was provided by the audit.</p>
      {% endif %}
    </div>
  </section>

  {% if business_risks %}
  <h2>Business risks</h2>
  {% for risk in business_risks %}
    <div class="banner banner-amber">{{ risk }}</div>
  {% endfor %}
  {% endif %}

  {% if warnings or assumptions %}
  <h2>Audit notes</h2>
  <section class="grid">
    <div class="card span-6">
      <h3>Warnings</h3>
      {% if warnings %}<ul>{% for warning in warnings %}<li>{{ warning }}</li>{% endfor %}</ul>{% else %}<p class="empty">No warnings.</p>{% endif %}
    </div>
    <div class="card span-6">
      <h3>Assumptions</h3>
      {% if assumptions %}<ul>{% for assumption in assumptions %}<li>{{ assumption }}</li>{% endfor %}</ul>{% else %}<p class="empty">No assumptions.</p>{% endif %}
    </div>
  </section>
  {% endif %}

  <div class="footer">
    <strong>Technical appendix:</strong>
      raw agent outputs included = {{ audit_metadata.raw_agent_outputs_included }};
      DPP JSON used as source = {{ audit_metadata.dpp_json_used_as_source }}.
      Product facts and audit semantics come from {{ audit_metadata.source_label }} only.
      Internal source id: {{ audit_metadata.source }}.
  </div>
</div>
</body>
</html>
