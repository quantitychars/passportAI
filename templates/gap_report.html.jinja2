<!DOCTYPE html>
{# templates/gap_report.html.jinja2 — Compliance Gap Report HTML template #}
{# Variables: product_name, espr_category, readiness_score, score_breakdown, #}
{#            missing_essential, missing_recommended, inconsistencies, #}
{#            compliance_flags, recommended_actions, generated_at #}
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>DPP Compliance Gap Report — {{ product_name }}</title>
  <style>
    @page { size: A4; margin: 2cm 2.5cm; }
    * { box-sizing: border-box; }
    body { font-family: Arial, Helvetica, sans-serif; font-size: 10pt; color: #111; line-height: 1.5; }
    h1 { font-size: 18pt; color: #1a56db; margin-bottom: 4pt; }
    h2 { font-size: 12pt; color: #1a56db; margin: 16pt 0 6pt; border-bottom: 1pt solid #d1d5db; padding-bottom: 3pt; }
    h3 { font-size: 10pt; color: #374151; margin: 10pt 0 4pt; }
    .header-block { margin-bottom: 16pt; }
    .meta { color: #6b7280; font-size: 9pt; }
    .score-box {
      border: 2pt solid #1a56db;
      padding: 12pt;
      border-radius: 6pt;
      display: inline-block;
      margin: 8pt 0;
    }
    .score-number { font-size: 28pt; font-weight: bold; color: #1a56db; }
    .score-label { font-size: 9pt; color: #6b7280; }
    .progress-bar-bg { background: #e5e7eb; height: 10pt; border-radius: 5pt; overflow: hidden; margin: 4pt 0; }
    .progress-bar { height: 10pt; border-radius: 5pt; }
    table { width: 100%; border-collapse: collapse; margin: 8pt 0; font-size: 9pt; }
    th { background: #f3f4f6; text-align: left; padding: 5pt 8pt; font-size: 8pt; font-weight: bold; text-transform: uppercase; letter-spacing: 0.4pt; border: 1pt solid #e5e7eb; }
    td { padding: 5pt 8pt; border: 1pt solid #e5e7eb; vertical-align: top; }
    tr:nth-child(even) td { background: #f9fafb; }
    .badge { display: inline-block; padding: 1pt 5pt; border-radius: 3pt; font-size: 8pt; font-weight: bold; }
    .badge-red { background: #fee2e2; color: #991b1b; }
    .badge-yellow { background: #fef3c7; color: #92400e; }
    .badge-green { background: #d1fae5; color: #065f46; }
    .badge-gray { background: #f3f4f6; color: #374151; }
    .alert { padding: 8pt; border-left: 3pt solid; margin: 8pt 0; border-radius: 0 4pt 4pt 0; font-size: 9pt; }
    .alert-red { border-color: #e02424; background: #fff5f5; }
    .alert-yellow { border-color: #c27803; background: #fffbeb; }
    .alert-green { border-color: #0e9f6e; background: #f0fdf4; }
    .footer { margin-top: 24pt; padding-top: 8pt; border-top: 1pt solid #e5e7eb; font-size: 8pt; color: #9ca3af; }
    .page-break { page-break-before: always; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12pt; }
  </style>
</head>
<body>

{# Cover / Header #}
<div class="header-block">
  <h1>DPP Compliance Gap Report</h1>
  <p class="meta">Product: <strong>{{ product_name }}</strong> &nbsp;|&nbsp; Category: <strong>{{ espr_category | upper }}</strong> &nbsp;|&nbsp; Generated: {{ generated_at }}</p>
  <p class="meta">Generated by PassportAI v1.0 using Gemma 4 12B · This report is AI-generated and requires human review before official use.</p>
</div>

{# Executive Summary #}
<h2>Executive Summary</h2>
<div class="grid-2">
  <div>
    <div class="score-box">
      <div class="score-number">{{ readiness_score }}</div>
      <div class="score-label">/ 100 — DPP Readiness Score</div>
    </div>
    <p style="font-size:9pt; margin-top:4pt; color:#374151">
      {% if readiness_score >= 75 %}
        <strong style="color:#065f46">Ready for EU market submission.</strong> Minor gaps remain.
      {% elif readiness_score >= 50 %}
        <strong style="color:#92400e">Attention required.</strong> Address high-priority gaps before submission.
      {% else %}
        <strong style="color:#991b1b">Not ready.</strong> Critical information missing. Substantial work required.
      {% endif %}
    </p>
  </div>
  <div>
    <h3>Score Breakdown</h3>
    {% for label, value, max_val in [
      ('Essential Fields', score_breakdown.essential_fields, 60),
      ('Recommended Fields', score_breakdown.recommended_fields, 25),
      ('Documents Attached', score_breakdown.documents_attached, 10),
      ('Photo Standardized', score_breakdown.photo_standardized, 5)
    ] %}
    <div style="margin-bottom:4pt">
      <div style="display:flex; justify-content:space-between; font-size:8pt">
        <span>{{ label }}</span><span>{{ value }}/{{ max_val }}</span>
      </div>
      <div class="progress-bar-bg">
        <div class="progress-bar" style="width:{{ (value / max_val * 100) | int }}%; background: {{ '#0e9f6e' if (value/max_val) > 0.7 else ('#c27803' if (value/max_val) > 0.4 else '#e02424') }};"></div>
      </div>
    </div>
    {% endfor %}
  </div>
</div>

{# Critical Gaps #}
{% if missing_essential %}
<h2>Critical Gaps (Essential Fields Missing)</h2>
<div class="alert alert-red">
  <strong>{{ missing_essential | length }} essential field(s) missing.</strong>
  These fields are required before the passport can be submitted to EU authorities.
</div>
<table>
  <thead><tr><th>Field</th><th>Why Required</th><th>ESPR Deadline</th><th>Priority</th></tr></thead>
  <tbody>
  {% for field in missing_essential %}
  <tr>
    <td><code>{{ field }}</code></td>
    <td>Required for all ESPR DPP submissions</td>
    <td>2027-01-01</td>
    <td><span class="badge badge-red">CRITICAL</span></td>
  </tr>
  {% endfor %}
  </tbody>
</table>
{% endif %}

{# Recommended Fields #}
{% if missing_recommended %}
<h2>Recommended Fields</h2>
<table>
  <thead><tr><th>Field</th><th>Benefit</th><th>Priority</th></tr></thead>
  <tbody>
  {% for field in missing_recommended %}
  <tr>
    <td><code>{{ field }}</code></td>
    <td>Improves market readiness and buyer confidence</td>
    <td><span class="badge badge-yellow">RECOMMENDED</span></td>
  </tr>
  {% endfor %}
  </tbody>
</table>
{% endif %}

{# Inconsistencies #}
{% if inconsistencies %}
<h2>Data Inconsistencies</h2>
{% for issue in inconsistencies %}
<div class="alert alert-yellow">{{ issue }}</div>
{% endfor %}
{% endif %}

{# Recommended Actions #}
{% if recommended_actions %}
<h2>Recommended Actions</h2>
<table>
  <thead><tr><th>#</th><th>Action</th><th>Effort</th><th>Cost</th></tr></thead>
  <tbody>
  {% for action in recommended_actions %}
  <tr>
    <td>{{ loop.index }}</td>
    <td>
      <strong>{{ action.action }}</strong>
      {% if action.how_to %}<br><span style="color:#6b7280">{{ action.how_to }}</span>{% endif %}
    </td>
    <td>{{ action.estimated_effort or '—' }}</td>
    <td>{{ action.cost_estimate or '—' }}</td>
  </tr>
  {% endfor %}
  </tbody>
</table>
{% endif %}

{# Footer #}
<div class="footer">
  <strong>PassportAI</strong> — ESPR Digital Product Passport Generator &nbsp;|&nbsp;
  Generated using Gemma 4 12B Q4_K_M (100% offline) &nbsp;|&nbsp;
  License: CC-BY 4.0 &nbsp;|&nbsp;
  <em>AI-generated report. Consult a qualified compliance professional for official submissions.</em>
</div>

</body>
</html>
