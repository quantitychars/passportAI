<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Digital Product Passport — {{ product.name }}</title>
  <meta name="description" content="Human-readable Digital Product Passport generated by PassportAI">
  <style>
    :root {
      --bg: #f4f4f2;
      --paper: #ffffff;
      --paper-soft: #fbfbf9;
      --ink: #101828;
      --ink-soft: #344054;
      --muted: #667085;
      --line: #d8dde6;
      --line-soft: #edf0f4;
      --accent: #111827;
      --accent-soft: #f3f4f6;
      --danger: #b42318;
      --danger-bg: #fef3f2;
      --warning: #b54708;
      --warning-bg: #fffaeb;
      --success: #027a48;
      --success-bg: #ecfdf3;
      --blue: #175cd3;
      --blue-bg: #eff8ff;
      --shadow: 0 16px 48px rgba(15, 23, 42, 0.08);
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      background:
        radial-gradient(circle at top left, rgba(17, 24, 39, 0.035), transparent 34rem),
        var(--bg);
      color: var(--ink);
      font-family: Inter, "Segoe UI", Arial, sans-serif;
      line-height: 1.55;
    }

    .loading-screen {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #ffffff;
      transition: opacity 0.42s ease, visibility 0.42s ease;
    }

    .loading-screen.hidden {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }

    .loading-words {
      display: grid;
      gap: 2px;
      text-align: center;
      color: #111827;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(28px, 4vw, 46px);
      font-weight: 700;
      line-height: 0.96;
      letter-spacing: 0.01em;
    }

    .loading-words span {
      display: block;
      animation: loadingDrift 1.25s ease-in-out infinite;
    }

    .loading-words span:nth-child(2) {
      animation-delay: 0.12s;
    }

    .loading-words span:nth-child(3) {
      animation-delay: 0.24s;
    }

    @keyframes loadingDrift {
      0%, 100% { transform: translateX(-8px); opacity: 0.42; }
      50% { transform: translateX(8px); opacity: 1; }
    }

    .page {
      max-width: 1360px;
      margin: 0 auto;
      padding: 28px 20px 56px;
    }

    .passport-shell {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 312px;
      gap: 24px;
      align-items: start;
    }

    .passport-document {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 30px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .document-header {
      padding: 30px 34px 24px;
      border-bottom: 1px solid var(--line);
      background:
        linear-gradient(135deg, rgba(255,255,255,1), rgba(248,250,252,0.94)),
        var(--paper);
    }

    .document-kicker {
      margin: 0 0 14px;
      color: var(--muted);
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .document-title {
      margin: 0;
      max-width: 920px;
      color: var(--ink);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(40px, 5vw, 70px);
      font-weight: 700;
      line-height: 0.96;
      letter-spacing: -0.045em;
    }

    .document-subtitle {
      margin: 18px 0 0;
      max-width: 900px;
      color: var(--ink-soft);
      font-size: 18px;
      line-height: 1.55;
    }

    .document-main {
      padding: 30px 34px 36px;
    }

    .top-grid {
      display: grid;
      grid-template-columns: 330px minmax(0, 1fr);
      gap: 30px;
      align-items: stretch;
    }

    .photo-panel {
      border: 1px solid var(--line);
      border-radius: 24px;
      background: var(--paper-soft);
      padding: 18px;
      min-width: 0;
    }

    .photo-label {
      margin: 0 0 14px;
      color: var(--muted);
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .photo-frame {
      position: relative;
      min-height: 360px;
      border: 1px solid var(--line-soft);
      border-radius: 20px;
      background: #ffffff;
      padding: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .photo-frame img {
      display: block;
      max-width: 100%;
      max-height: 300px;
      object-fit: contain;
    }

    .image-fallback {
      display: none;
      min-height: 260px;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: var(--muted);
      font-size: 13px;
      padding: 18px;
    }

    .photo-reference {
      margin: 12px 0 0;
      color: var(--muted);
      font-size: 12px;
      overflow-wrap: anywhere;
    }

    .summary-panel {
      display: flex;
      flex-direction: column;
      gap: 20px;
      min-width: 0;
    }

    .primary-facts {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px 24px;
    }

    .primary-fact {
      min-width: 0;
      border-bottom: 1px solid var(--line);
      padding-bottom: 14px;
    }

    .primary-fact.wide {
      grid-column: 1 / -1;
    }

    .label {
      display: block;
      margin: 0 0 6px;
      color: var(--muted);
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.13em;
      text-transform: uppercase;
    }

    .value {
      display: block;
      color: var(--ink);
      font-size: 20px;
      font-weight: 650;
      line-height: 1.25;
      overflow-wrap: anywhere;
    }

    .value.large {
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(30px, 4vw, 44px);
      font-weight: 700;
      letter-spacing: -0.035em;
    }

    .value.small {
      font-size: 16px;
    }

    .section {
      margin-top: 34px;
      padding-top: 26px;
      border-top: 1px solid var(--line);
    }

    .section-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 18px;
    }

    .section-title {
      margin: 0;
      color: var(--ink);
      font-family: Georgia, "Times New Roman", serif;
      font-size: 27px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .section-note {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 14px;
    }

    .fact-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .fact {
      min-width: 0;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: #ffffff;
      padding: 15px 16px;
    }

    .fact strong {
      display: block;
      color: var(--ink);
      font-size: 17px;
      font-weight: 650;
      line-height: 1.32;
      overflow-wrap: anywhere;
    }

    .status-list {
      display: grid;
      gap: 12px;
    }

    .status-item {
      min-width: 0;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: #ffffff;
      padding: 16px;
    }

    .status-item.missing {
      border-color: #fecdca;
      background: #fffafa;
    }

    .status-item h3 {
      margin: 0 0 6px;
      font-size: 16px;
      color: var(--ink);
    }

    .status-item p {
      margin: 0;
      color: var(--ink-soft);
    }

    .definition-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .definition-item {
      min-width: 0;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: #ffffff;
      padding: 16px;
    }

    .definition-item h3 {
      margin: 0 0 8px;
      color: var(--ink);
      font-size: 16px;
      line-height: 1.25;
    }

    .definition-value {
      display: inline-flex;
      max-width: 100%;
      border-radius: 999px;
      padding: 6px 10px;
      background: var(--accent-soft);
      color: var(--ink);
      font-size: 13px;
      font-weight: 800;
      overflow-wrap: anywhere;
    }

    .definition-value.missing {
      background: var(--warning-bg);
      color: var(--warning);
    }

    .definition-description {
      margin: 10px 0 0;
      color: var(--muted);
      font-size: 13px;
    }

    .evidence-summary {
      display: grid;
      grid-template-columns: 220px minmax(0, 1fr);
      gap: 18px;
      align-items: start;
    }

    .evidence-metrics {
      display: grid;
      gap: 12px;
    }

    .metric-box {
      border: 1px solid var(--line);
      border-radius: 18px;
      background: var(--paper-soft);
      padding: 16px;
    }

    .metric-box strong {
      display: block;
      color: var(--ink);
      font-size: 30px;
      line-height: 1;
      margin-top: 4px;
    }

    .missing-list {
      display: grid;
      gap: 10px;
    }

    .missing-item {
      border: 1px solid var(--line);
      border-radius: 18px;
      background: #ffffff;
      padding: 14px 16px;
    }

    .missing-item h3 {
      margin: 0 0 4px;
      font-size: 15px;
      color: var(--ink);
    }

    .missing-item p {
      margin: 0;
      color: var(--ink-soft);
      font-size: 13px;
    }

    .technical-rows {
      display: grid;
      gap: 10px;
    }

    .technical-row {
      display: grid;
      grid-template-columns: 180px minmax(0, 1fr);
      gap: 14px;
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 13px 14px;
      background: #ffffff;
    }

    .technical-row .label {
      margin: 0;
    }

    .mono {
      font-family: "SFMono-Regular", Consolas, Menlo, monospace;
      font-size: 12px;
      line-height: 1.45;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .muted {
      color: var(--muted);
    }

    .small {
      font-size: 13px;
    }

    .side-rail {
      display: grid;
      gap: 16px;
      position: sticky;
      top: 20px;
    }

    .rail-card {
      border: 1px solid var(--line);
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.9);
      box-shadow: var(--shadow);
      padding: 18px;
      backdrop-filter: blur(10px);
    }

    .rail-title {
      margin: 0 0 14px;
      color: var(--muted);
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .tool-stack {
      display: grid;
      gap: 10px;
    }

    .tool-btn {
      display: block;
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: #ffffff;
      color: var(--ink);
      padding: 12px 14px;
      text-align: left;
      text-decoration: none;
      font: inherit;
      font-weight: 750;
      cursor: pointer;
    }

    .tool-btn.primary {
      border-color: var(--accent);
      background: var(--accent);
      color: #ffffff;
    }

    .tool-btn:hover {
      transform: translateY(-1px);
    }

    .chip {
      display: inline-flex;
      align-items: center;
      max-width: 100%;
      border-radius: 999px;
      padding: 6px 10px;
      margin: 0 6px 8px 0;
      font-size: 12px;
      font-weight: 850;
      line-height: 1;
    }

    .chip.draft {
      background: var(--warning-bg);
      color: var(--warning);
    }

    .chip.blocked {
      background: var(--danger-bg);
      color: var(--danger);
    }

    .chip.ready {
      background: var(--success-bg);
      color: var(--success);
    }

    .chip.info {
      background: var(--blue-bg);
      color: var(--blue);
    }

    .rail-metric {
      margin-top: 12px;
      padding-top: 12px;
      border-top: 1px solid var(--line);
    }

    .rail-metric-value {
      display: block;
      margin-top: 5px;
      color: var(--ink);
      font-size: 24px;
      font-weight: 750;
      line-height: 1.1;
      overflow-wrap: anywhere;
    }

    .rail-metric-value.small {
      font-size: 17px;
    }

    .footer {
      margin-top: 18px;
      color: var(--muted);
      text-align: center;
      font-size: 12px;
    }

    @media (max-width: 1120px) {
      .passport-shell {
        grid-template-columns: 1fr;
      }

      .side-rail {
        position: static;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 860px) {
      .document-main,
      .document-header {
        padding-left: 20px;
        padding-right: 20px;
      }

      .top-grid,
      .evidence-summary {
        grid-template-columns: 1fr;
      }

      .fact-grid,
      .definition-list,
      .primary-facts {
        grid-template-columns: 1fr;
      }

      .side-rail {
        grid-template-columns: 1fr;
      }

      .technical-row {
        grid-template-columns: 1fr;
      }
    }

    @media print {
      body {
        background: #ffffff;
      }

      .loading-screen,
      .side-rail {
        display: none !important;
      }

      .page {
        max-width: none;
        padding: 0;
      }

      .passport-shell {
        display: block;
      }

      .passport-document {
        border: 0;
        border-radius: 0;
        box-shadow: none;
      }

      .document-header,
      .document-main {
        padding-left: 0;
        padding-right: 0;
      }

      .section,
      .photo-panel,
      .fact,
      .status-item,
      .definition-item,
      .technical-row {
        break-inside: avoid;
      }

      a {
        color: inherit;
        text-decoration: none;
      }
    }
  </style>
</head>

<body>
<div id="loading-screen" class="loading-screen" aria-hidden="true">
  <div class="loading-words" aria-label="Loading Digital Product Passport">
    <span>Digital</span>
    <span>Product</span>
    <span>Passport</span>
  </div>
</div>

<div class="page">
  <div class="passport-shell">
    <main class="passport-document">
      <header class="document-header">
        <div class="document-kicker">PassportAI · Human-readable Digital Product Passport</div>
        <h1 class="document-title">{{ product.name }}</h1>
        <p class="document-subtitle">{{ product.description }}</p>
      </header>

      <div class="document-main">
        <section class="top-grid" aria-label="Product overview">
          <aside class="photo-panel">
            <h2 class="photo-label">Product Image</h2>
            {% if product.image_url %}
              <div class="photo-frame">
                <img src="{{ product.image_url }}" alt="{{ product.name }}" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <div class="image-fallback">
                  Product image is referenced but is not available inside this package yet.
                </div>
              </div>
              <p class="photo-reference">Image reference: <span class="mono">{{ product.image_url }}</span></p>
            {% else %}
              <div class="photo-frame">
                <div class="image-fallback" style="display:flex;">No product image attached.</div>
              </div>
            {% endif %}
          </aside>

          <div class="summary-panel">
            <div class="primary-facts">
              <div class="primary-fact wide">
                <span class="label">Product Name</span>
                <span class="value large">{{ product.name }}</span>
              </div>

              <div class="primary-fact">
                <span class="label">Brand</span>
                <span class="value">{{ product.brand }}</span>
              </div>

              <div class="primary-fact">
                <span class="label">Product Group</span>
                <span class="value">{{ product.group_label }}</span>
              </div>

              <div class="primary-fact">
                <span class="label">ESPR Category</span>
                <span class="value small">{{ product.espr_category }}</span>
              </div>

              <div class="primary-fact">
                <span class="label">Credential Subject</span>
                <span class="value small mono">{{ passport.credential_subject_id }}</span>
              </div>
            </div>

            <div class="fact-grid">
              <div class="fact">
                <label>Model</label>
                <strong>{{ product.model_name }} / {{ product.model_number }}</strong>
              </div>
              <div class="fact">
                <label>Serial / Batch</label>
                <strong>{{ product.serial_number }} / {{ product.batch_lot }}</strong>
              </div>
              <div class="fact">
                <label>CN Code</label>
                <strong>{{ product.cn_code }}</strong>
              </div>
              <div class="fact">
                <label>Granularity</label>
                <strong>{{ product.granularity_level }}</strong>
              </div>
            </div>
          </div>
        </section>

        <section class="section" aria-label="Identifiers">
          <div class="section-head">
            <div>
              <h2 class="section-title">Identifiers</h2>
              <p class="section-note">Stable identifiers used to link this passport to product, operator, and facility records.</p>
            </div>
          </div>

          <div class="status-list">
            <article class="status-item">
              <h3>Persistent Product Identifier</h3>
              <p class="mono">{{ identifiers.product.value }}</p>
              <p class="small muted">Scheme: {{ identifiers.product.scheme }} · Issuer: {{ identifiers.product.issuing_body }}</p>
            </article>

            <article class="status-item">
              <h3>Economic Operator Identifier</h3>
              <p class="mono">{{ identifiers.operator.value }}</p>
              <p class="small muted">Scheme: {{ identifiers.operator.scheme }}</p>
            </article>

            <article class="status-item">
              <h3>Manufacturing Facility Identifier</h3>
              <p class="mono">{{ identifiers.facility.value }}</p>
              <p class="small muted">Scheme: {{ identifiers.facility.scheme }}</p>
            </article>
          </div>
        </section>

        <section class="section" aria-label="Data carrier and operator">
          <div class="section-head">
            <div>
              <h2 class="section-title">Data Carrier And Operator</h2>
              <p class="section-note">How this passport is resolved and who is responsible for the product record.</p>
            </div>
          </div>

          <div class="fact-grid">
            <div class="fact">
              <label>Data Carrier Type</label>
              <strong>{{ data_carrier.type }}</strong>
            </div>
            <div class="fact">
              <label>Data Carrier Standard</label>
              <strong>{{ data_carrier.standard }}</strong>
            </div>
            <div class="fact">
              <label>Physical Placement</label>
              <strong>{{ data_carrier.placement }}</strong>
            </div>
            <div class="fact">
              <label>Persistence</label>
              <strong>{{ data_carrier.persistence_label }}</strong>
            </div>
            <div class="fact">
              <label>Resolver URL</label>
              <strong class="mono">{{ data_carrier.resolver_url }}</strong>
            </div>
            <div class="fact">
              <label>Carrier Value</label>
              <strong class="mono">{{ data_carrier.carrier_value }}</strong>
            </div>
            <div class="fact">
              <label>Responsible Operator</label>
              <strong>{{ operator.name }}</strong>
            </div>
            <div class="fact">
              <label>Operator Role</label>
              <strong>{{ operator.role }}</strong>
            </div>
          </div>
        </section>

        <section class="section" aria-label="Compliance status">
          <div class="section-head">
            <div>
              <h2 class="section-title">Compliance Evidence</h2>
              <p class="section-note">Document references required to defend regulated passport claims.</p>
            </div>
          </div>

          <div class="status-list">
            <article class="status-item {{ 'missing' if not compliance.declaration_present else '' }}">
              <h3>Declaration Of Conformity</h3>
              <p>{{ 'Present' if compliance.declaration_present else 'Not attached or not referenced' }}</p>
              <p class="small muted">Reference: {{ compliance.declaration_reference }} · URL: {{ compliance.declaration_url }}</p>
            </article>

            <article class="status-item {{ 'missing' if not compliance.technical_present else '' }}">
              <h3>Technical Documentation</h3>
              <p>{{ 'Present' if compliance.technical_present else 'Not attached or not referenced' }}</p>
              <p class="small muted">Reference: {{ compliance.technical_reference }} · URL: {{ compliance.technical_url }}</p>
            </article>
          </div>
        </section>

        <section class="section" aria-label="Sector passport data">
          <div class="section-head">
            <div>
              <h2 class="section-title">{{ sector.title }}</h2>
              <p class="section-note">Sector-specific passport data projected from the machine-readable DPP.</p>
            </div>
          </div>

          {% if sector["items"] %}
            <div class="definition-list">
              {% for item in sector["items"] %}
                <article class="definition-item">
                  <h3>{{ item.label }}</h3>
                  <span class="definition-value {{ 'missing' if item.is_missing else '' }}">{{ item.value }}</span>
                  <p class="definition-description">{{ item.description }}</p>
                </article>
              {% endfor %}
            </div>
          {% else %}
            <p class="muted">No sector-specific passport data is available for this product group.</p>
          {% endif %}
        </section>

        <section class="section" aria-label="Evidence readiness">
          <div class="section-head">
            <div>
              <h2 class="section-title">Evidence Readiness</h2>
              <p class="section-note">This passport remains a draft until missing supplier or master-data evidence is resolved.</p>
            </div>
          </div>

          <div class="evidence-summary">
            <div class="evidence-metrics">
              <div class="metric-box">
                <span class="label">Total Missing Fields</span>
                <strong>{{ evidence.missing_count }}</strong>
              </div>
              <div class="metric-box">
                <span class="label">Required / Critical Missing</span>
                <strong>{{ evidence.required_missing_count }}</strong>
              </div>
            </div>

            <div class="missing-list">
              {% if evidence.top_missing_fields %}
                {% for gap in evidence.top_missing_fields %}
                  {% if loop.index <= 4 %}
                    <article class="missing-item">
                      <h3>{{ gap.field_label }}</h3>
                      <p>{{ gap.action }}</p>
                    </article>
                  {% endif %}
                {% endfor %}
              {% else %}
                <article class="missing-item">
                  <h3>No Missing Evidence Projected</h3>
                  <p>The generated passport artifact does not list missing evidence fields.</p>
                </article>
              {% endif %}
            </div>
          </div>
        </section>

        <section class="section" aria-label="Access control">
          <div class="section-head">
            <div>
              <h2 class="section-title">Access Control</h2>
              <p class="section-note">Public and restricted sections declared for this passport package.</p>
            </div>
          </div>

          <div class="fact-grid">
            <div class="fact">
              <label>Public Sections</label>
              <strong>{{ access_control.public_sections | join(', ') if access_control.public_sections else 'Not specified' }}</strong>
            </div>
            <div class="fact">
              <label>Confidential Sections</label>
              <strong>{{ access_control.confidential_sections | join(', ') if access_control.confidential_sections else 'None declared' }}</strong>
            </div>
          </div>
        </section>

        <section class="section" aria-label="Technical appendix">
          <div class="section-head">
            <div>
              <h2 class="section-title">Technical Appendix</h2>
              <p class="section-note">Technical metadata for verification and traceability.</p>
            </div>
          </div>

          <div class="technical-rows">
            <div class="technical-row">
              <span class="label">VC ID</span>
              <span class="mono">{{ passport.id }}</span>
            </div>
            <div class="technical-row">
              <span class="label">Passport ID</span>
              <span class="mono">{{ passport.passport_id }}</span>
            </div>
            <div class="technical-row">
              <span class="label">Issuer</span>
              <span>{{ passport.issuer_name }} · <span class="mono">{{ passport.issuer_id }}</span></span>
            </div>
            <div class="technical-row">
              <span class="label">Valid From / Until</span>
              <span>{{ passport.valid_from }} / {{ passport.valid_until }}</span>
            </div>
            <div class="technical-row">
              <span class="label">Schema Version</span>
              <span>{{ technical.schema_version }}</span>
            </div>
            <div class="technical-row">
              <span class="label">Generator</span>
              <span>{{ technical.generator_name }} {{ technical.generator_version }} · {{ technical.generation_method }}</span>
            </div>
            <div class="technical-row">
              <span class="label">Content Hash</span>
              <span class="mono">{{ technical.content_hash }}</span>
            </div>
          </div>

          <p class="small muted" style="margin-top:14px">
            Generated {{ generated_at }}. This HTML view is a projection of passport.json and does not recalculate audit verdicts or product facts.
          </p>
        </section>
      </div>
    </main>

    <aside class="side-rail" aria-label="Passport workspace">
      <section class="rail-card">
        <h2 class="rail-title">Workspace Tools</h2>
        <div class="tool-stack">
          <a class="tool-btn primary" href="{{ links.gap_report }}">View Gap Report</a>
          <a class="tool-btn" href="{{ links.passport_json }}">Download JSON</a>
          <button class="tool-btn" type="button" onclick="window.print()">Save as PDF</button>
        </div>
      </section>

      <section class="rail-card">
        <h2 class="rail-title">Document Status</h2>

        {% if passport.is_draft %}
          <span class="chip draft">Draft Passport</span>
        {% else %}
          <span class="chip ready">Issued Passport</span>
        {% endif %}

        {% if passport.readiness_score >= 80 %}
          <span class="chip ready">{{ passport.readiness_label }}</span>
        {% else %}
          <span class="chip blocked">{{ passport.readiness_label }}</span>
        {% endif %}

        <div class="rail-metric">
          <span class="label">Readiness Score</span>
          <span class="rail-metric-value">{{ passport.readiness_score }}/100</span>
        </div>

        <div class="rail-metric">
          <span class="label">Passport Status</span>
          <span class="rail-metric-value small">{{ passport.status_label }}</span>
        </div>

        <div class="rail-metric">
          <span class="label">Human Review</span>
          <span class="rail-metric-value small">{{ passport.human_review_label }}</span>
        </div>
      </section>

      <section class="rail-card">
        <h2 class="rail-title">Machine-readable Artifact</h2>
        <p class="small muted">
          This page is a human-readable projection. The machine-readable Digital Product Passport is available as JSON.
        </p>
        <p class="mono">{{ links.passport_json }}</p>
      </section>
    </aside>
  </div>

  <div class="footer">
    PassportAI Digital Product Passport · Human-readable projection of the machine-readable DPP credential.
  </div>
</div>

<script>
  window.addEventListener("load", function () {
    const loader = document.getElementById("loading-screen");
    if (!loader) {
      return;
    }

    setTimeout(function () {
      loader.classList.add("hidden");
    }, 450);
  });
</script>
</body>
</html>
