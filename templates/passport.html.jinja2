<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Digital Product Passport — {{ product.name }}</title>
  <meta name="description" content="Human-readable Digital Product Passport generated by PassportAI">
  <style>
    :root {
      --bg: #f6f7fb;
      --card: #ffffff;
      --text: #111827;
      --muted: #6b7280;
      --line: #e5e7eb;
      --blue: #1d4ed8;
      --blue-bg: #eff6ff;
      --green: #047857;
      --green-bg: #ecfdf5;
      --amber: #b45309;
      --amber-bg: #fffbeb;
      --red: #b91c1c;
      --red-bg: #fef2f2;
      --shadow: 0 14px 40px rgba(15, 23, 42, 0.08);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.55;
    }
    .page { max-width: 1120px; margin: 0 auto; padding: 28px 18px 48px; }
    .hero {
      background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 100%);
      color: white;
      border-radius: 28px;
      padding: 30px;
      box-shadow: var(--shadow);
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 24px;
      align-items: start;
    }
    .eyebrow { font-size: 12px; letter-spacing: .12em; text-transform: uppercase; opacity: .78; font-weight: 800; }
    h1 { margin: 8px 0 8px; font-size: clamp(30px, 5vw, 54px); line-height: 1; }
    h2 { margin: 0 0 14px; font-size: 20px; }
    h3 { margin: 0 0 8px; font-size: 16px; }
    p { margin: 0 0 10px; }
    .hero p { color: rgba(255,255,255,.82); max-width: 720px; }
    .status-panel {
      min-width: 220px;
      background: rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.22);
      border-radius: 22px;
      padding: 18px;
      backdrop-filter: blur(10px);
    }
    .score { font-size: 44px; font-weight: 900; line-height: 1; }
    .score small { font-size: 16px; color: rgba(255,255,255,.72); }
    .toolbar { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px; }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border: 1px solid rgba(255,255,255,.28);
      border-radius: 999px;
      padding: 10px 14px;
      color: white;
      background: rgba(255,255,255,.16);
      text-decoration: none;
      font-weight: 750;
      cursor: pointer;
    }
    .btn-dark { background: #111827; border-color: #111827; }
    .btn-light { background: white; color: #111827; border-color: white; }
    .grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 16px; margin-top: 16px; }
    .span-12 { grid-column: span 12; }
    .span-8 { grid-column: span 8; }
    .span-6 { grid-column: span 6; }
    .span-4 { grid-column: span 4; }
    .card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 22px;
      padding: 22px;
      box-shadow: 0 1px 2px rgba(15, 23, 42, .04);
    }
    .muted { color: var(--muted); }
    .small { font-size: 13px; }
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border-radius: 999px;
      padding: 5px 10px;
      font-size: 12px;
      font-weight: 800;
      white-space: nowrap;
      background: #f3f4f6;
      color: #374151;
    }
    .pill-blue { background: var(--blue-bg); color: var(--blue); }
    .pill-green { background: var(--green-bg); color: var(--green); }
    .pill-amber { background: var(--amber-bg); color: var(--amber); }
    .pill-red { background: var(--red-bg); color: var(--red); }
    .facts { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
    .fact {
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 13px;
      background: #fff;
      min-width: 0;
    }
    .fact label { display: block; color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: .08em; font-weight: 900; }
    .fact strong { display: block; margin-top: 3px; word-break: break-word; }
    .image-frame {
      background: #f9fafb;
      border: 1px solid var(--line);
      border-radius: 18px;
      min-height: 220px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .image-frame img { width: 100%; height: 100%; max-height: 320px; object-fit: contain; }
    table { width: 100%; border-collapse: collapse; }
    th, td { text-align: left; padding: 10px 8px; border-bottom: 1px solid var(--line); vertical-align: top; }
    th { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: .08em; }
    .status-list { display: grid; gap: 10px; }
    .status-item { border: 1px solid var(--line); border-radius: 16px; padding: 13px; }
    .status-item.missing { border-color: #fecaca; background: #fff7f7; }
    code, .mono { font-family: "SFMono-Regular", Consolas, Menlo, monospace; font-size: 12px; }
    details { margin-top: 10px; }
    summary { cursor: pointer; font-weight: 800; }
    .footer { margin-top: 18px; color: var(--muted); text-align: center; font-size: 12px; }
    @media (max-width: 820px) {
      .hero { grid-template-columns: 1fr; }
      .span-8, .span-6, .span-4 { grid-column: span 12; }
      .facts { grid-template-columns: 1fr; }
      .status-panel { min-width: unset; }
    }
    @media print {
      body { background: white; }
      .page { max-width: none; padding: 0; }
      .card, .hero { box-shadow: none; break-inside: avoid; }
      .toolbar { display: none; }
      a { color: inherit; text-decoration: none; }
    }
  </style>
</head>
<body>
<div class="page">
  <section class="hero">
    <div>
      <div class="eyebrow">PassportAI · Digital Product Passport</div>
      <h1>{{ product.name }}</h1>
      <p>{{ product.description }}</p>
      <div class="toolbar">
        <a class="btn btn-light" href="{{ links.gap_report }}">View Gap Report</a>
        <a class="btn" href="{{ links.passport_json }}">Download JSON</a>
        <button class="btn" type="button" onclick="window.print()">Save as PDF</button>
      </div>
    </div>
    <aside class="status-panel">
      <div class="eyebrow">Readiness</div>
      <div class="score">{{ passport.readiness_score }}<small>/100</small></div>
      <p><strong>{{ passport.readiness_label }}</strong></p>
      <p class="small">Status: {{ passport.status_label }} · Human review: {{ passport.human_review_label }}</p>
      {% if passport.is_draft %}
        <span class="pill pill-amber">Draft passport</span>
      {% else %}
        <span class="pill pill-green">Issued passport</span>
      {% endif %}
    </aside>
  </section>

  <section class="grid">
    <div class="card span-8">
      <h2>Product identity</h2>
      <div class="facts">
        <div class="fact"><label>Brand</label><strong>{{ product.brand }}</strong></div>
        <div class="fact"><label>Product group</label><strong>{{ product.group_label }}</strong></div>
        <div class="fact"><label>ESPR category</label><strong>{{ product.espr_category }}</strong></div>
        <div class="fact"><label>CN code</label><strong>{{ product.cn_code }}</strong></div>
        <div class="fact"><label>Model</label><strong>{{ product.model_name }} / {{ product.model_number }}</strong></div>
        <div class="fact"><label>Serial / batch</label><strong>{{ product.serial_number }} / {{ product.batch_lot }}</strong></div>
        <div class="fact"><label>Granularity</label><strong>{{ product.granularity_level }}</strong></div>
        <div class="fact"><label>Credential subject</label><strong class="mono">{{ passport.credential_subject_id }}</strong></div>
      </div>
    </div>

    <div class="card span-4">
      <h2>Product photo</h2>
      {% if product.image_url %}
        <div class="image-frame"><img src="{{ product.image_url }}" alt="{{ product.name }}"></div>
        <p class="small muted" style="margin-top:10px">Image reference: <span class="mono">{{ product.image_url }}</span></p>
      {% else %}
        <div class="image-frame"><p class="muted">No product image attached.</p></div>
      {% endif %}
    </div>
  </section>

  <section class="grid">
    <div class="card span-6">
      <h2>Identifiers</h2>
      <div class="status-list">
        <div class="status-item">
          <h3>Persistent product identifier</h3>
          <p class="mono">{{ identifiers.product.value }}</p>
          <p class="small muted">Scheme: {{ identifiers.product.scheme }} · Issuer: {{ identifiers.product.issuing_body }}</p>
        </div>
        <div class="status-item">
          <h3>Economic operator identifier</h3>
          <p class="mono">{{ identifiers.operator.value }}</p>
          <p class="small muted">Scheme: {{ identifiers.operator.scheme }}</p>
        </div>
        <div class="status-item">
          <h3>Manufacturing facility identifier</h3>
          <p class="mono">{{ identifiers.facility.value }}</p>
          <p class="small muted">Scheme: {{ identifiers.facility.scheme }}</p>
        </div>
      </div>
    </div>

    <div class="card span-6">
      <h2>Data carrier</h2>
      <div class="facts">
        <div class="fact"><label>Type</label><strong>{{ data_carrier.type }}</strong></div>
        <div class="fact"><label>Standard</label><strong>{{ data_carrier.standard }}</strong></div>
        <div class="fact"><label>Placement</label><strong>{{ data_carrier.placement }}</strong></div>
        <div class="fact"><label>Persistence</label><strong>{{ data_carrier.persistence_label }}</strong></div>
      </div>
      <p class="small muted" style="margin-top:12px">Resolver URL</p>
      <p class="mono">{{ data_carrier.resolver_url }}</p>
      <p class="small muted">Carrier value</p>
      <p class="mono">{{ data_carrier.carrier_value }}</p>
    </div>
  </section>

  <section class="grid">
    <div class="card span-6">
      <h2>Responsible economic operator</h2>
      <div class="facts">
        <div class="fact"><label>Name</label><strong>{{ operator.name }}</strong></div>
        <div class="fact"><label>Role</label><strong>{{ operator.role }}</strong></div>
        <div class="fact"><label>Identifier ref</label><strong>{{ operator.identifier_ref }}</strong></div>
        <div class="fact"><label>Country</label><strong>{{ operator.country }}</strong></div>
        <div class="fact"><label>Email</label><strong>{{ operator.email }}</strong></div>
        <div class="fact"><label>Website</label><strong>{{ operator.website }}</strong></div>
      </div>
    </div>

    <div class="card span-6">
      <h2>Compliance status</h2>
      <div class="status-list">
        <div class="status-item {{ 'missing' if not compliance.declaration_present else '' }}">
          <h3>Declaration of conformity</h3>
          <p>{{ 'Present' if compliance.declaration_present else 'Not attached or not referenced' }}</p>
          <p class="small muted">Reference: {{ compliance.declaration_reference }} · URL: {{ compliance.declaration_url }}</p>
        </div>
        <div class="status-item {{ 'missing' if not compliance.technical_present else '' }}">
          <h3>Technical documentation</h3>
          <p>{{ 'Present' if compliance.technical_present else 'Not attached or not referenced' }}</p>
          <p class="small muted">Reference: {{ compliance.technical_reference }} · URL: {{ compliance.technical_url }}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="grid">
    <div class="card span-12">
      <h2>{{ sector.title }}</h2>
      {% if sector["items"] %}
      <table>
        <thead><tr><th>Field</th><th>Value</th><th>Why it matters</th></tr></thead>
        <tbody>
        {% for item in sector["items"] %}
          <tr>
            <td><strong>{{ item.label }}</strong></td>
            <td>{% if item.is_missing %}<span class="pill pill-amber">{{ item.value }}</span>{% else %}{{ item.value }}{% endif %}</td>
            <td class="muted small">{{ item.description }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
      {% else %}
        <p class="muted">No sector-specific passport data is available for this product group.</p>
      {% endif %}
    </div>
  </section>

  <section class="grid">
    <div class="card span-8">
      <h2>Evidence readiness</h2>
      <p>
        This passport is a product-data artifact. It does not hide missing supplier evidence:
        unresolved fields are shown here and the full remediation plan is available in the Gap Report.
      </p>
      <div class="facts" style="margin:14px 0">
        <div class="fact"><label>Total missing fields</label><strong>{{ evidence.missing_count }}</strong></div>
        <div class="fact"><label>Required / critical missing</label><strong>{{ evidence.required_missing_count }}</strong></div>
      </div>
      {% if evidence.top_missing_fields %}
      <table>
        <thead><tr><th>Missing evidence</th><th>Severity</th><th>Action</th></tr></thead>
        <tbody>
        {% for gap in evidence.top_missing_fields %}
          <tr>
            <td><strong>{{ gap.field_label }}</strong><br><span class="mono muted">{{ gap.field }}</span></td>
            <td><span class="pill {{ 'pill-red' if gap.severity in ['critical', 'required'] else 'pill-amber' }}">{{ gap.severity_label }}</span></td>
            <td>{{ gap.action }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
      {% else %}
        <p class="muted">No missing fields were projected into this passport artifact.</p>
      {% endif %}
    </div>

    <div class="card span-4">
      <h2>Access control</h2>
      <h3>Public sections</h3>
      <p>{{ access_control.public_sections | join(', ') if access_control.public_sections else 'Not specified' }}</p>
      <h3>Confidential sections</h3>
      <p>{{ access_control.confidential_sections | join(', ') if access_control.confidential_sections else 'None declared' }}</p>
      <details>
        <summary>Restricted sections</summary>
        <pre class="mono">{{ access_control.restricted_sections }}</pre>
      </details>
    </div>
  </section>

  <section class="grid">
    <div class="card span-12">
      <h2>Technical appendix</h2>
      <div class="facts">
        <div class="fact"><label>VC ID</label><strong class="mono">{{ passport.id }}</strong></div>
        <div class="fact"><label>Passport ID</label><strong class="mono">{{ passport.passport_id }}</strong></div>
        <div class="fact"><label>Issuer</label><strong>{{ passport.issuer_name }} · <span class="mono">{{ passport.issuer_id }}</span></strong></div>
        <div class="fact"><label>Valid from / until</label><strong>{{ passport.valid_from }} / {{ passport.valid_until }}</strong></div>
        <div class="fact"><label>Schema version</label><strong>{{ technical.schema_version }}</strong></div>
        <div class="fact"><label>Generator</label><strong>{{ technical.generator_name }} {{ technical.generator_version }} · {{ technical.generation_method }}</strong></div>
        <div class="fact span-12"><label>Content hash</label><strong class="mono">{{ technical.content_hash }}</strong></div>
      </div>
      <p class="small muted" style="margin-top:12px">
        Generated {{ generated_at }}. This HTML view is a projection of passport.json and does not recalculate audit verdicts or product facts.
      </p>
    </div>
  </section>

  <div class="footer">
    PassportAI Digital Product Passport · Human-readable projection of the machine-readable DPP credential.
  </div>
</div>
</body>
</html>
